# =============================================================================
# Шаблон для EAS Environment Variables / Secrets (TravelHub)
# =============================================================================
# 1) Скопируйте файл:  copy eas-secrets.template.env  eas-secrets.production.env
# 2) Заполните значения (из Firebase Console, Sentry, своего .env).
# 3) Залейте в EAS (профиль из eas.json):
#      npx eas env:push production --path eas-secrets.production.env
#      npx eas env:push preview     --path eas-secrets.preview.env
# 4) В expo.dev → Project → Environment variables отметьте секреты как Sensitive.
#
# Не коммитьте заполненный eas-secrets.*.env с реальными ключами (добавьте в .gitignore).
# =============================================================================

# --- Профиль билда (для app.config.js: production|preview → без cleartext, без TOURVISOR в бандле)
APP_ENV=production

# --- Expo / EAS (можно не задавать, если совпадает с app.config.js)
EAS_PROJECT_ID=0f6984f9-e3d1-46f5-ae15-dd0e5b4deef2
EXPO_OWNER=s1kata12

# --- Сайт (без слэша в конце)
PAYMENT_PAGE_URL=https://travelhub63.ru
WEBSITE_BASE_URL=https://travelhub63.ru
# Альтернатива для websiteBaseUrl в коде (если используете):
# EXPO_PUBLIC_WEBSITE_BASE_URL=https://travelhub63.ru

# --- Firebase (веб-приложение в консоли Firebase → Project settings → Your apps)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# --- CRM: для production/preview ключ U-ON в клиент НЕ кладётся (только прокси на сайте).
# Оставьте пустым в store-сборках. SOTA_CRM_BASE_URL — только для локальной отладки base URL CRM.
SOTA_CRM_BASE_URL=
# НЕ задавайте в production store (ключ попадёт в бандл):
# EXPO_PUBLIC_UON_API_KEY=
# (устаревшее EXPO_PUBLIC_SOTA_API_KEY в app.config.js читается как fallback)

# --- Сервер Node (`/server`): ключ UON_API_KEY задаётся в .env на хосте, не обязательно в EAS приложения.
# UON_API_KEY=

# --- Sentry: ошибки в рантайме (DSN публичный, но лучше через EAS)
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_SENTRY_ENABLE_IN_DEV=0

# --- Sentry: загрузка source maps при EAS Build (плагин в app.config.js включается, если все три заданы)
SENTRY_URL=https://sentry.io/
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# --- Tourvisor: в production/preview JWT не попадает в бандл (прокси на сайте).
# Имеет смысл для development-сборки / локального .env; в EAS production можно не задавать.
# TOURVISOR_TOKEN=
# TOURVISOR_JWT_TOKEN=
# TOURVISOR_API_URL=
# TOURVISOR_WORKER_URL=

# --- Опционально: картинки (если используете в приложении)
# EXPO_PUBLIC_IMAGE_STORAGE_PROVIDER=
# EXPO_PUBLIC_CLOUDINARY_UPLOAD_URL=
# EXPO_PUBLIC_CLOUDINARY_API_KEY=
# EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=
# EXPO_PUBLIC_IMGBB_API_KEY=

# --- Опционально: свой API (см. src/api/apiClient.ts)
# EXPO_PUBLIC_API_BASE=
