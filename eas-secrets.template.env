# =============================================================================
# EAS mobile — шаблон (cp eas-secrets.template.env eas-secrets.production.env)
# npm run eas:env-push:production
# =============================================================================

APP_ENV=production
EAS_PROJECT_ID=0f6984f9-e3d1-46f5-ae15-dd0e5b4deef2
EXPO_OWNER=s1kata12
IOS_BUNDLE_ID=com.iliastravelhub.app
ANDROID_PACKAGE=com.iliastravelhub.app

SITE_BASE_URL=https://travelhub63.ru
AUTH_API_BASE_URL=https://travelhub63.ru
AUTH_API_PATH=/api/auth-mobile.php
CRM_API_BASE_URL=https://travelhub63.ru
BONUS_API_BASE_URL=https://travelhub63.ru
PAYMENT_API_BASE_URL=https://travelhub63.ru
TOURVISOR_API_URL=https://travelhub63.ru/api/tourvisor-mobile

# Должен в точности совпадать с health_check_token в api/auth-mobile.config.php.
# Перед env:push раскомментируйте и подставьте реальный секрет.
# HEALTH_CHECK_TOKEN=replace-with-server-health-token

EXPO_PUBLIC_SENTRY_ENABLE_IN_DEV=0
IOS_ENABLE_PUSH=1

# Опционально Sentry (только с реальными значениями, иначе push упадёт):
# EXPO_PUBLIC_SENTRY_DSN=https://...
# SENTRY_URL=https://sentry.io/
# SENTRY_ORG=your-org
# SENTRY_PROJECT=travelhub
# SENTRY_AUTH_TOKEN=sntrys_...

# Не пушить если account-wide: WEBSITE_BASE_URL
# Секреты сервера (JWT, UON, Tinkoff) — не в EAS, см. docs/ENV_MAP.md
