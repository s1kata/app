# Скопируйте в .env в корне проекта (рядом с app.config.js). На проде — только на сервере, не в клиенте.

# --- Firebase Admin (Node: create-payment, webhook, CRM) ---
# Вариант A: путь к JSON service account
GOOGLE_APPLICATION_CREDENTIALS=
# Вариант B: JSON одной строкой (для PaaS)
# FIREBASE_SERVICE_ACCOUNT=

# --- Tinkoff (только сервер) ---
TINKOFF_TERMINAL_KEY=
TINKOFF_PASSWORD=

# Публичные URL приложения
APP_URL=https://travelhub63.ru
API_URL=https://travelhub63.ru
PAYMENT_SERVER_PORT=3334

# --- U-ON (только сервер; устаревшее имя SOTA_API_KEY поддерживается как fallback в коде) ---
UON_API_KEY=

# --- Auth-mobile JWT (тот же секрет, что в auth-mobile.config.php) ---
JWT_SECRET=
JWT_ISSUER=travelhub-auth
AUTH_MOBILE_JWT_SECRET=

# --- Клиент Expo (не секреты платежей/CRM) ---
# PAYMENT_PAGE_URL=https://travelhub63.ru
