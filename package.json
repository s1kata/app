{
  "name": "travelhub",
  "version": "1.0.3",
  "main": "index.ts",
  "description": "TravelHub - Your Ultimate Travel Companion",
  "author": "TravelHub Team",
  "scripts": {
    "icon:sync": "node scripts/generateBrandIcon.js",
    "start": "npm run icon:sync && expo start",
    "android": "npm run icon:sync && expo run:android",
    "ios": "npm run icon:sync && expo run:ios",
    "web": "expo start --web",
    "eas:env-push": "eas env:push production --path eas-secrets.production.env",
    "eas:env-push:production": "eas env:push production --path eas-secrets.production.env",
    "eas:env-push:preview": "eas env:push preview --path eas-secrets.preview.env",
    "build:development": "eas build --profile development",
    "build:android:dev": "eas build --profile development --platform android",
    "build:preview": "eas build --profile preview --platform android",
    "build:production": "eas build --profile production",
    "build:production:ios": "eas build --profile production --platform ios",
    "build:production:android": "eas build --profile production --platform android",
    "build:production:all": "eas build --profile production --platform all",
    "update:preview": "eas update --channel preview --environment preview",
    "update:production": "eas update --channel production --environment production",
    "update:list": "eas update:list --branch production --limit 10",
    "submit:production:ios": "eas submit --profile production --platform ios",
    "submit:production:android": "eas submit --profile production --platform android",
    "server": "node server/index.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 200",
    "lint:strict": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.9.1",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/stack": "^7.0.0",
    "@sentry/react-native": "~7.2.0",
    "@tanstack/react-query": "^5.59.0",
    "expo": "~54.0.36",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.12",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.11",
    "firebase": "^12.8.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-webview": "^13.8.6"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "dotenv": "^16.6.1",
    "eslint": "^8.56.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "express": "^4.21.0",
    "firebase-admin": "^13.7.0",
    "sharp": "^0.35.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
