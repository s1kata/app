# Скопируйте в .env в корне проекта (рядом с app.config.js).
# После изменения: npx expo start --clear

# --- Firebase (клиент, публичные ключи из Firebase Console → Project settings) ---
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

# --- URL приложения ---
WEBSITE_BASE_URL=https://travelhub63.ru
PAYMENT_PAGE_URL=https://travelhub63.ru
